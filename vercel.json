{
  "headers": [
    {
      "source": "/portfolio",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://proposal-dashboard-blond.vercel.app https://*.vercel.app http://localhost:*"
        }
      ]
    },
    {
      "source": "/case-studies/:path*",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://proposal-dashboard-blond.vercel.app https://*.vercel.app http://localhost:*"
        }
      ]
    }
  ]
}
